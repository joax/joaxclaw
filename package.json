{
  "name": "joaxclaw",
  "version": "0.12.3",
  "description": "Electron UI for Openclaw Gateway",
  "license": "MIT",
  "author": {
    "name": "Joaquin Ayuso",
    "email": "joaxap@gmail.com"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "build": "electron-vite build",
    "preview": "unset ELECTRON_RUN_AS_NODE && electron-vite preview",
    "start": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "package:linux": "npm run build && electron-builder --linux deb --x64",
    "package:mac": "npm run build && electron-builder --mac dmg --universal",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "check-secrets": "node scripts/check-secrets.mjs",
    "audit-secrets": "node scripts/check-secrets.mjs --all",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check-secrets && npm run lint && npm run type-check && npm test"
  },
  "build": {
    "appId": "com.joax.joaxclaw",
    "productName": "JoaxClaw",
    "copyright": "Copyright © 2026 Joaquin Ayuso",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "plugins/joaxclaw-fs/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "resources/icons/macos/joaxclaw-1024.png",
      "identity": null
    },
    "dmg": {
      "title": "JoaxClaw ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "resources/icons/linux/joaxclaw-512.png",
      "maintainer": "Joaquin Ayuso <joaxap@gmail.com>",
      "description": "Electron UI for Openclaw Gateway"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icons/windows/icon.ico"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libdrm2",
        "libgbm1",
        "libxcb-dri3-0"
      ]
    }
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@types/ws": "^8.18.1",
    "d3-force": "^3.0.0",
    "diff": "^9.0.0",
    "monaco-editor": "^0.52.2",
    "react-markdown": "^10.1.0",
    "refractor": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "systeminformation": "^5.25.11",
    "ws": "^8.21.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.2",
    "electron-builder": "^26.15.2",
    "electron-vite": "^3.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "lucide-react": "^0.469.0",
    "playwright-core": "^1.60.0",
    "postcss": "^8.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^4.1.8"
  }
}
